# Database Credentials (Neon / Local PostgreSQL)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/mediflow
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# Server Settings
PORT=8080
SPRING_PROFILES_ACTIVE=prod

# Authentication Security (Hex-encoded 256-bit string)
JWT_SECRET=generaterandom256bitkeyinhexformatforsecurityinproduction

# Allowed CORS Origins (comma-separated patterns)
# Can also use: MEDIFLOW_CORS_ALLOWED_ORIGINS (takes precedence over ALLOWED_ORIGINS)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://*.vercel.app,https://mediflow-care.vercel.app,https://mediflow.vercel.app
