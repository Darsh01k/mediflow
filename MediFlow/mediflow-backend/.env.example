# Copy this file to .env and fill in your values

# Database Credentials (Neon / Local PostgreSQL)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/mediflow
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=YOUR_DB_PASSWORD_HERE

# Server Settings
PORT=8080
SPRING_PROFILES_ACTIVE=prod

# Authentication Security (Base64-encoded 256-bit key)
JWT_SECRET=YOUR_BASE64_ENCODED_256_BIT_SECRET_HERE

# Google OAuth2 Credentials (optional - only needed for Google login)
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET_HERE

# Allowed CORS Origins (comma-separated patterns)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://*.vercel.app,https://mediflow-care.vercel.app,https://mediflow.vercel.app
