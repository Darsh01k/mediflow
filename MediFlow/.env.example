# ==============================================================================
# MediFlow Environment Configuration Example
# ==============================================================================

# --- DATABASE CONFIG (Neon PostgreSQL / Local) ---
# Format: jdbc:postgresql://<host>:<port>/<dbname>?sslmode=require
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/mediflow
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# --- SPRING BOOT / RUNTIME CONFIG ---
PORT=8080
SPRING_PROFILES_ACTIVE=prod
JWT_SECRET=generaterandom256bitkeyinhexformatforsecurityinproduction

# --- CORS SETTINGS ---
# Comma-separated list of origins allowed to connect to the API
ALLOWED_ORIGINS=http://localhost:5173,https://*.vercel.app,https://mediflow.vercel.app

# --- FRONTEND CLIENT CONFIG ---
# URL of the deployed backend server (e.g. Render Web Service URL)
VITE_API_URL=https://mediflow-backend.onrender.com/api
